# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Auth.js v5 reads AUTH_SECRET (NEXTAUTH_SECRET also accepted). Generate with:
#   openssl rand -base64 32
AUTH_SECRET=change_me
NEXTAUTH_SECRET=change_me
NODE_ENV=development

# ---------------------------------------------------------------------------
# Custom app database (postgres-app)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://app:password@postgres-app:5432/strawberry_platform?schema=public
POSTGRES_APP_USER=app
POSTGRES_APP_PASSWORD=password
POSTGRES_APP_DB=strawberry_platform

# Seed super admin (dev only)
SEED_ADMIN_EMAIL=admin@strawberry.local
SEED_ADMIN_PASSWORD=ChangeMe!123

# ---------------------------------------------------------------------------
# pretix
# ---------------------------------------------------------------------------
PRETIX_BASE_URL=http://pretix:80
PRETIX_API_TOKEN=change_me
# Dev/seed default only. Production resolves the organizer from the event mapping.
PRETIX_DEFAULT_ORGANIZER=strawberry

# pretix database (postgres-pretix)
POSTGRES_PRETIX_USER=pretix
POSTGRES_PRETIX_PASSWORD=pretix_password
POSTGRES_PRETIX_DB=pretix

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# SMTP default/fallback (configurable per-organizer in admin)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Strawberry Agency
SMTP_FROM_EMAIL=noreply@strawberryagency.com
SMTP_SECURE=false

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
API_KEY_PEPPER=change_me
WEBHOOK_SECRET=change_me

# ---------------------------------------------------------------------------
# Future integrations (placeholders — disabled until configured)
# ---------------------------------------------------------------------------
WHISH_API_BASE_URL=
WHISH_CLIENT_ID=
WHISH_CLIENT_SECRET=
WHISH_WEBHOOK_SECRET=
SMS_PROVIDER=
SMS_API_KEY=
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=

# ---------------------------------------------------------------------------
# Cloudflare / reverse proxy
# ---------------------------------------------------------------------------
TRUST_PROXY=true
