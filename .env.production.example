# =============================================================================
# Strawberry Events — PRODUCTION environment (example / placeholders only)
# =============================================================================
# Copy to `.env` on the production host and fill with STRONG, UNIQUE values.
# `.env` is gitignored — never commit real secrets.
#
# The app fail-fasts at startup (apps/web/src/lib/config/env.ts) if any required
# secret is missing, empty, weak, or a known placeholder (change_me / dev-secret /
# secret / password / ...). compose.yaml keeps dev-friendly fallbacks so it parses
# without a root .env in development — the app-level validator is the authoritative
# production guard, so production MUST set strong values here.
#
# Generate strong secrets:
#   openssl rand -base64 32      # AUTH_SECRET, MAGIC_LINK_SECRET, PRETIX_WEBHOOK_SECRET
#   openssl rand -base64 32      # ENCRYPTION_KEY  (must decode to exactly 32 bytes)
# -----------------------------------------------------------------------------

NODE_ENV=production

# Public base URL — MUST be https:// in production (secure cookies require HTTPS).
APP_URL=https://events.example.com
NEXTAUTH_URL=https://events.example.com

# Auth / signing / encryption (REQUIRED, strong)
AUTH_SECRET=__generate_openssl_rand_base64_32__
MAGIC_LINK_SECRET=__generate_openssl_rand_base64_32__
ENCRYPTION_KEY=__generate_openssl_rand_base64_32__   # base64, decodes to 32 bytes

# Database
POSTGRES_APP_USER=app
POSTGRES_APP_PASSWORD=__strong_db_password__
POSTGRES_APP_DB=strawberry_platform
# (DATABASE_URL is composed in compose.yaml from the POSTGRES_APP_* vars,
#  pointing at the in-network host `postgres-app:5432` — NOT localhost:5433.)

# pretix
PRETIX_BASE_URL=http://pretix:80
PRETIX_API_TOKEN=__pretix_api_token__
PRETIX_DEFAULT_ORGANIZER=strawberry
PRETIX_WEBHOOK_SECRET=__generate_openssl_rand_base64_32__   # sent as X-Pretix-Webhook-Secret header

# First admin (seed)
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_PASSWORD=__strong_admin_password__

# Outbound email — REQUIRED in production unless explicitly disabled below.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=__smtp_user__
SMTP_PASSWORD=__smtp_password__
SMTP_FROM_NAME=Strawberry Agency
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_SECURE=false
# Set true ONLY to run production intentionally without outbound email.
ALLOW_EMAIL_DISABLED_IN_PRODUCTION=false

# =============================================================================
# Secret rotation & recovery — READ BEFORE DEPLOY
# =============================================================================
# * The pretix token and ENCRYPTION_KEY used during development MUST be rotated
#   before production (treat any value seen in dev/.env as compromised).
# * ENCRYPTION_KEY encrypts integration secrets at rest (AES-256-GCM). If you
#   rotate or LOSE this key, all stored encrypted integration secrets become
#   unreadable and must be re-entered in the admin UI. There is no key-rotation
#   migration yet — re-enter SMTP/WhatsApp/SMS/Whish/pretix tokens after rotation.
# * Back up ENCRYPTION_KEY securely and SEPARATELY from the database backup.
# * Rotate AUTH_SECRET/MAGIC_LINK_SECRET only during a maintenance window
#   (rotating invalidates existing sessions and outstanding magic-link tickets).
